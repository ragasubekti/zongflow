<?xml version="1.0" encoding="UTF-8"?>
  <interface domain="zongflow">
  <template class="SettingsWidget" parent="GtkBox">
    <property name="visible">True</property>
    <property name="hexpand">True</property>
    <property name="vexpand">True</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="AdwToastOverlay" id="toast_overlay">
        <property name="visible">True</property>
        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
        <child>
          <object class="AdwPreferencesPage">
            <property name="visible">True</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">General</property>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Language</property>
                    <property name="subtitle" translatable="yes">Application language</property>
                    <child type="suffix">
                      <object class="GtkDropDown" id="language_dropdown">
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Dark Mode</property>
                    <property name="subtitle" translatable="yes">Use dark theme</property>
                    <child type="suffix">
                      <object class="GtkSwitch" id="dark_mode_switch">
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Output Folder</property>
                    <property name="subtitle" translatable="yes">Where converted files are saved</property>
                    <child type="suffix">
                      <object class="GtkButton" id="output_folder_button">
                        <property name="label" translatable="yes">Choose</property>
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="AdwPreferencesGroup">
                <property name="title" translatable="yes">Maintenance</property>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Clear Cache</property>
                    <property name="subtitle" translatable="yes">Delete temporary files</property>
                    <child type="suffix">
                      <object class="GtkButton" id="clear_cache_button">
                        <property name="label" translatable="yes">Clear</property>
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                        <property name="css-classes">destructive-action</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Clear Database</property>
                    <property name="subtitle" translatable="yes">Remove all library data</property>
                    <child type="suffix">
                      <object class="GtkButton" id="clear_database_button">
                        <property name="label" translatable="yes">Clear</property>
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                        <property name="css-classes">destructive-action</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">Reset Settings</property>
                    <property name="subtitle" translatable="yes">Restore defaults</property>
                    <child type="suffix">
                      <object class="GtkButton" id="reset_settings_button">
                        <property name="label" translatable="yes">Reset</property>
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                        <property name="css-classes">destructive-action</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="AdwActionRow">
                    <property name="title" translatable="yes">About</property>
                    <property name="subtitle" translatable="yes">Application information</property>
                    <child type="suffix">
                      <object class="GtkButton" id="about_button">
                        <property name="label" translatable="yes">About</property>
                        <property name="halign">end</property>
                        <property name="valign">center</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child type="end">
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">6</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <child>
          <object class="GtkButton" id="save_button">
            <property name="label" translatable="yes">Save</property>
            <property name="halign">end</property>
            <property name="hexpand">True</property>
            <property name="css-classes">suggested-action</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
