<?xml version="1.0" encoding="UTF-8"?>
  <interface domain="zongflow">
  <template class="ZongflowWindow" parent="AdwWindow">
    <property name="default-width">900</property>
    <property name="default-height">700</property>
    <property name="content">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar" id="header_bar">
            <child type="start">
              <object class="AdwSplitButton" id="import_button">
                <property name="icon-name">list-add-symbolic</property>
                <property name="label" translatable="yes">Import</property>
                <property name="action-name">app.import-file</property>
                <property name="tooltip-text" translatable="yes">Import</property>

              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="settings_button">
                <property name="icon-name">preferences-system-symbolic</property>
                <property name="tooltip-text" translatable="yes">Settings</property>
              </object>
            </child>
            <child type="end">
              <object class="AdwToggleGroup" id="view_toggle_group">
                <property name="visible">False</property>
                <child>
                  <object class="AdwToggle">
                    <property name="icon-name">view-list-symbolic</property>
                    <property name="name">list</property>
                    <property name="tooltip" translatable="yes">List View</property>
                  </object>
                </child>
                <child>
                  <object class="AdwToggle">
                    <property name="icon-name">view-grid-symbolic</property>
                    <property name="name">grid</property>
                    <property name="tooltip" translatable="yes">Grid View</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwViewStack" id="stack">
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
          </object>
        </property>
        <child type="bottom">
          <object class="AdwViewSwitcherBar" id="switcher_bar">
            <property name="stack">stack</property>
            <property name="reveal">True</property>
          </object>
        </child>
      </object>
    </property>
  </template>

</interface>
